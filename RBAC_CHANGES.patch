+# Supabase Migration
+
+Apply migrations to a staging project first:
+
+```bash
+supabase db push
+```
+
+The RBAC migration replaces policies on the managed tables. Back up the
+database and review any custom policies before deployment.
+
+Bootstrap the first admin after the migration:
+
+```sql
+update public.profiles
+set role = 'admin'
+where email = 'admin@example.com';
+```
+
+Existing `tasks` remain in place and are exposed through the new Reminder
+domain model. Existing class leader strings such as `Ketua Kelas` and
+`Wakil Ketua Kelas` remain supported during migration.
diff --git a/supabase/migrations/202606120001_rbac_modules.sql b/supabase/migrations/202606120001_rbac_modules.sql
new file mode 100644
index 0000000..6fd039e
--- /dev/null
+++ b/supabase/migrations/202606120001_rbac_modules.sql
@@ -0,0 +1,553 @@
+begin;
+
+create table if not exists public.profiles (
+  id uuid primary key references auth.users(id) on delete cascade,
+  email text not null unique,
+  display_name text not null default 'Pengguna',
+  student_number text,
+  role text not null default 'student'
+    check (role in ('admin', 'lecturer', 'class_leader', 'student')),
+  avatar_url text,
+  created_at timestamptz not null default now(),
+  updated_at timestamptz not null default now()
+);
+
+insert into public.profiles (
+  id,
+  email,
+  display_name,
+  student_number,
+  role,
+  avatar_url
+)
+select
+  users.id,
+  coalesce(users.email, ''),
+  coalesce(users.raw_user_meta_data ->> 'name', 'Pengguna'),
+  users.raw_user_meta_data ->> 'nim',
+  case lower(coalesce(users.raw_user_meta_data ->> 'role', 'student'))
+    when 'admin' then 'admin'
+    when 'lecturer' then 'lecturer'
+    when 'dosen' then 'lecturer'
+    when 'class_leader' then 'class_leader'
+    when 'ketua kelas' then 'class_leader'
+    else 'student'
+  end,
+  users.raw_user_meta_data ->> 'avatar_url'
+from auth.users
+on conflict (id) do nothing;
+
+update public.profiles profile
+set role = 'class_leader'
+where profile.role = 'student'
+  and exists (
+    select 1
+    from public.anggota_kelas member
+    where lower(member.user_email) = lower(profile.email)
+      and lower(member.role) in ('ketua kelas', 'ketua', 'class_leader')
+  );
+
+create or replace function public.handle_new_user()
+returns trigger
+language plpgsql
+security definer
+set search_path = public
+as $$
+begin
+  insert into public.profiles (
+    id,
+    email,
+    display_name,
+    student_number,
+    role,
+    avatar_url
+  )
+  values (
+    new.id,
+    coalesce(new.email, ''),
+    coalesce(new.raw_user_meta_data ->> 'name', 'Pengguna'),
+    new.raw_user_meta_data ->> 'nim',
+    'student',
+    new.raw_user_meta_data ->> 'avatar_url'
+  )
+  on conflict (id) do update
+  set
+    email = excluded.email,
+    display_name = excluded.display_name,
+    student_number = excluded.student_number,
+    avatar_url = excluded.avatar_url,
+    updated_at = now();
+  return new;
+end;
+$$;
+
+drop trigger if exists on_auth_user_created on auth.users;
+create trigger on_auth_user_created
+  after insert or update of email, raw_user_meta_data on auth.users
+  for each row execute function public.handle_new_user();
+
+create or replace function public.current_user_role()
+returns text
+language sql
+stable
+security definer
+set search_path = public
+as $$
+  select case
+    when coalesce(
+      (select role from public.profiles where id = auth.uid()),
+      'student'
+    ) = 'student'
+    and exists (
+      select 1
+      from public.anggota_kelas member
+      where lower(member.user_email) =
+        lower(coalesce(auth.jwt() ->> 'email', ''))
+        and lower(member.role) in (
+          'admin',
+          'ketua kelas',
+          'ketua',
+          'class_leader'
+        )
+    )
+      then 'class_leader'
+    else coalesce(
+      (select role from public.profiles where id = auth.uid()),
+      'student'
+    )
+  end;
+$$;
+
+create or replace function public.is_admin()
+returns boolean
+language sql
+stable
+security definer
+set search_path = public
+as $$
+  select public.current_user_role() = 'admin';
+$$;
+
+create or replace function public.is_class_member(class_id bigint)
+returns boolean
+language sql
+stable
+security definer
+set search_path = public
+as $$
+  select exists (
+    select 1
+    from public.anggota_kelas member
+    where member.kelas_id = class_id
+      and lower(member.user_email) =
+        lower(coalesce(auth.jwt() ->> 'email', ''))
+  );
+$$;
+
+create or replace function public.is_class_leader(class_id bigint)
+returns boolean
+language sql
+stable
+security definer
+set search_path = public
+as $$
+  select exists (
+    select 1
+    from public.anggota_kelas member
+    where member.kelas_id = class_id
+      and lower(member.user_email) =
+        lower(coalesce(auth.jwt() ->> 'email', ''))
+      and lower(member.role) in (
+        'admin',
+        'ketua kelas',
+        'ketua',
+        'class_leader'
+      )
+  );
+$$;
+
+alter table if exists public.matakuliah
+  add column if not exists lecturer_id uuid references public.profiles(id);
+
+update public.matakuliah course
+set lecturer_id = profile.id
+from public.profiles profile
+where course.lecturer_id is null
+  and profile.role = 'lecturer'
+  and lower(trim(course.dosen)) = lower(trim(profile.display_name));
+
+create or replace function public.can_manage_class(class_id bigint)
+returns boolean
+language sql
+stable
+security definer
+set search_path = public
+as $$
+  select
+    public.is_admin()
+    or exists (
+      select 1
+      from public.kelas class
+      where class.id = class_id and class.created_by = auth.uid()
+    )
+    or public.is_class_leader(class_id)
+    or exists (
+      select 1
+      from public.matakuliah course
+      where course.kelas_id = class_id
+        and course.lecturer_id = auth.uid()
+    );
+$$;
+
+create or replace function public.prevent_unauthorized_role_change()
+returns trigger
+language plpgsql
+security definer
+set search_path = public
+as $$
+begin
+  if new.role is distinct from old.role and not public.is_admin() then
+    raise exception 'Only an admin can change user roles';
+  end if;
+  new.updated_at = now();
+  return new;
+end;
+$$;
+
+drop trigger if exists protect_profile_role on public.profiles;
+create trigger protect_profile_role
+  before update on public.profiles
+  for each row execute function public.prevent_unauthorized_role_change();
+
+alter table if exists public.tasks
+  add column if not exists created_by uuid references public.profiles(id),
+  add column if not exists target_role text
+    check (target_role is null or target_role in (
+      'admin',
+      'lecturer',
+      'class_leader',
+      'student'
+    )),
+  add column if not exists priority text not null default 'medium'
+    check (priority in ('low', 'medium', 'high', 'urgent')),
+  add column if not exists status text not null default 'pending'
+    check (status in ('pending', 'completed', 'expired'));
+
+update public.tasks task
+set created_by = profile.id
+from public.profiles profile
+where task.created_by is null
+  and lower(task.author_email) = lower(profile.email);
+
+create table if not exists public.announcements (
+  id bigint generated by default as identity primary key,
+  title text not null check (char_length(trim(title)) between 1 and 200),
+  content text not null check (char_length(trim(content)) between 1 and 10000),
+  created_by uuid not null
+    references public.profiles(id) on delete restrict,
+  target_class bigint references public.kelas(id) on delete cascade,
+  target_role text check (target_role is null or target_role in (
+    'admin',
+    'lecturer',
+    'class_leader',
+    'student'
+  )),
+  created_at timestamptz not null default now(),
+  updated_at timestamptz not null default now()
+);
+
+create index if not exists profiles_role_idx
+  on public.profiles(role);
+create index if not exists courses_lecturer_id_idx
+  on public.matakuliah(lecturer_id);
+create index if not exists tasks_target_idx
+  on public.tasks(kelas_id, target_role, waktu_reminder);
+create index if not exists announcements_target_idx
+  on public.announcements(target_class, target_role, created_at desc);
+
+create or replace function public.join_class(access_code text)
+returns bigint
+language plpgsql
+security definer
+set search_path = public
+as $$
+declare
+  target_class public.kelas%rowtype;
+  assigned_role text := 'student';
+  current_email text := coalesce(auth.jwt() ->> 'email', '');
+  current_profile public.profiles%rowtype;
+begin
+  if auth.uid() is null or trim(current_email) = '' then
+    raise exception 'Authentication required';
+  end if;
+
+  select *
+  into target_class
+  from public.kelas class
+  where upper(class.kode_kelas) = upper(trim(access_code))
+     or upper(class.kode_wakil) = upper(trim(access_code))
+  limit 1;
+
+  if not found then
+    raise exception 'Kode kelas tidak valid';
+  end if;
+  if not coalesce(target_class.is_open, true) then
+    raise exception 'Kelas sedang ditutup';
+  end if;
+  if upper(target_class.kode_wakil) = upper(trim(access_code)) then
+    assigned_role := 'class_leader';
+  end if;
+
+  select * into current_profile
+  from public.profiles
+  where id = auth.uid();
+
+  insert into public.anggota_kelas (
+    kelas_id,
+    user_email,
+    role,
+    user_name,
+    nim
+  )
+  values (
+    target_class.id,
+    current_email,
+    assigned_role,
+    coalesce(current_profile.display_name, 'Pengguna'),
+    coalesce(current_profile.student_number, '-')
+  )
+  on conflict do nothing;
+
+  return target_class.id;
+end;
+$$;
+
+alter table public.profiles enable row level security;
+alter table public.kelas enable row level security;
+alter table public.anggota_kelas enable row level security;
+alter table public.matakuliah enable row level security;
+alter table public.jadwal_kelas enable row level security;
+alter table public.tasks enable row level security;
+alter table public.announcements enable row level security;
+
+do $$
+declare
+  existing_policy record;
+begin
+  for existing_policy in
+    select schemaname, tablename, policyname
+    from pg_policies
+    where schemaname = 'public'
+      and tablename in (
+        'profiles',
+        'kelas',
+        'anggota_kelas',
+        'matakuliah',
+        'jadwal_kelas',
+        'tasks',
+        'announcements'
+      )
+  loop
+    execute format(
+      'drop policy if exists %I on %I.%I',
+      existing_policy.policyname,
+      existing_policy.schemaname,
+      existing_policy.tablename
+    );
+  end loop;
+end;
+$$;
+
+drop policy if exists profiles_select_rbac on public.profiles;
+create policy profiles_select_rbac on public.profiles
+  for select to authenticated
+  using (id = auth.uid() or public.is_admin());
+
+drop policy if exists profiles_update_rbac on public.profiles;
+create policy profiles_update_rbac on public.profiles
+  for update to authenticated
+  using (id = auth.uid() or public.is_admin())
+  with check (id = auth.uid() or public.is_admin());
+
+drop policy if exists classes_select_rbac on public.kelas;
+create policy classes_select_rbac on public.kelas
+  for select to authenticated
+  using (
+    public.is_admin()
+    or created_by = auth.uid()
+    or public.is_class_member(id)
+    or exists (
+      select 1
+      from public.matakuliah course
+      where course.kelas_id = id and course.lecturer_id = auth.uid()
+    )
+  );
+
+drop policy if exists classes_insert_rbac on public.kelas;
+create policy classes_insert_rbac on public.kelas
+  for insert to authenticated
+  with check (
+    created_by = auth.uid()
+    and public.current_user_role() in ('admin', 'lecturer', 'class_leader')
+  );
+
+drop policy if exists classes_update_rbac on public.kelas;
+create policy classes_update_rbac on public.kelas
+  for update to authenticated
+  using (public.can_manage_class(id))
+  with check (public.can_manage_class(id));
+
+drop policy if exists classes_delete_rbac on public.kelas;
+create policy classes_delete_rbac on public.kelas
+  for delete to authenticated
+  using (public.can_manage_class(id));
+
+drop policy if exists members_select_rbac on public.anggota_kelas;
+create policy members_select_rbac on public.anggota_kelas
+  for select to authenticated
+  using (
+    lower(user_email) = lower(coalesce(auth.jwt() ->> 'email', ''))
+    or public.can_manage_class(kelas_id)
+  );
+
+drop policy if exists members_insert_rbac on public.anggota_kelas;
+create policy members_insert_rbac on public.anggota_kelas
+  for insert to authenticated
+  with check (
+    lower(user_email) = lower(coalesce(auth.jwt() ->> 'email', ''))
+    or public.can_manage_class(kelas_id)
+  );
+
+drop policy if exists members_update_rbac on public.anggota_kelas;
+create policy members_update_rbac on public.anggota_kelas
+  for update to authenticated
+  using (public.can_manage_class(kelas_id))
+  with check (public.can_manage_class(kelas_id));
+
+drop policy if exists members_delete_rbac on public.anggota_kelas;
+create policy members_delete_rbac on public.anggota_kelas
+  for delete to authenticated
+  using (
+    lower(user_email) = lower(coalesce(auth.jwt() ->> 'email', ''))
+    or public.can_manage_class(kelas_id)
+  );
+
+drop policy if exists courses_select_rbac on public.matakuliah;
+create policy courses_select_rbac on public.matakuliah
+  for select to authenticated
+  using (
+    public.is_class_member(kelas_id)
+    or public.can_manage_class(kelas_id)
+  );
+
+drop policy if exists courses_write_rbac on public.matakuliah;
+create policy courses_write_rbac on public.matakuliah
+  for all to authenticated
+  using (public.can_manage_class(kelas_id))
+  with check (public.can_manage_class(kelas_id));
+
+drop policy if exists schedules_select_rbac on public.jadwal_kelas;
+create policy schedules_select_rbac on public.jadwal_kelas
+  for select to authenticated
+  using (
+    public.is_class_member(kelas_id)
+    or public.can_manage_class(kelas_id)
+  );
+
+drop policy if exists schedules_write_rbac on public.jadwal_kelas;
+create policy schedules_write_rbac on public.jadwal_kelas
+  for all to authenticated
+  using (public.can_manage_class(kelas_id))
+  with check (public.can_manage_class(kelas_id));
+
+drop policy if exists reminders_select_rbac on public.tasks;
+create policy reminders_select_rbac on public.tasks
+  for select to authenticated
+  using (
+    (
+      public.is_class_member(kelas_id)
+      or public.can_manage_class(kelas_id)
+    )
+    and (
+      target_role is null
+      or target_role = public.current_user_role()
+      or public.is_admin()
+    )
+  );
+
+drop policy if exists reminders_write_rbac on public.tasks;
+drop policy if exists reminders_insert_rbac on public.tasks;
+create policy reminders_insert_rbac on public.tasks
+  for insert to authenticated
+  with check (
+    public.can_manage_class(kelas_id)
+    and created_by = auth.uid()
+  );
+
+drop policy if exists reminders_update_rbac on public.tasks;
+create policy reminders_update_rbac on public.tasks
+  for update to authenticated
+  using (public.can_manage_class(kelas_id))
+  with check (public.can_manage_class(kelas_id));
+
+drop policy if exists reminders_delete_rbac on public.tasks;
+create policy reminders_delete_rbac on public.tasks
+  for delete to authenticated
+  using (public.can_manage_class(kelas_id));
+
+drop policy if exists announcements_select_rbac on public.announcements;
+create policy announcements_select_rbac on public.announcements
+  for select to authenticated
+  using (
+    (
+      target_role is null
+      or target_role = public.current_user_role()
+      or public.is_admin()
+    )
+    and (
+      target_class is null
+      or public.is_class_member(target_class)
+      or public.can_manage_class(target_class)
+    )
+  );
+
+drop policy if exists announcements_insert_rbac on public.announcements;
+create policy announcements_insert_rbac on public.announcements
+  for insert to authenticated
+  with check (
+    created_by = auth.uid()
+    and (
+      public.current_user_role() in ('admin', 'lecturer')
+      or (
+        public.current_user_role() = 'class_leader'
+        and target_class is not null
+        and public.is_class_leader(target_class)
+      )
+    )
+  );
+
+drop policy if exists announcements_update_rbac on public.announcements;
+create policy announcements_update_rbac on public.announcements
+  for update to authenticated
+  using (created_by = auth.uid() or public.is_admin())
+  with check (
+    (created_by = auth.uid() or public.is_admin())
+    and (
+      public.current_user_role() in ('admin', 'lecturer')
+      or (
+        public.current_user_role() = 'class_leader'
+        and target_class is not null
+        and public.is_class_leader(target_class)
+      )
+    )
+  );
+
+drop policy if exists announcements_delete_rbac on public.announcements;
+create policy announcements_delete_rbac on public.announcements
+  for delete to authenticated
+  using (created_by = auth.uid() or public.is_admin());
+
+grant execute on function public.join_class(text) to authenticated;
+grant execute on function public.current_user_role() to authenticated;
+
+commit;
diff --git a/test/rbac_models_test.dart b/test/rbac_models_test.dart
new file mode 100644
index 0000000..eaf352d
--- /dev/null
+++ b/test/rbac_models_test.dart
@@ -0,0 +1,83 @@
+import 'package:flutter_test/flutter_test.dart';
+import 'package:reminderkita/models/reminder.dart';
+import 'package:reminderkita/models/user_role.dart';
+
+void main() {
+  group('UserRole', () {
+    test('maps canonical and legacy role values', () {
+      expect(UserRole.fromValue('admin'), UserRole.admin);
+      expect(UserRole.fromValue('Dosen'), UserRole.lecturer);
+      expect(UserRole.fromValue('Ketua Kelas'), UserRole.classLeader);
+      expect(UserRole.fromValue('Wakil Ketua Kelas'), UserRole.classLeader);
+      expect(UserRole.fromValue('Mahasiswa'), UserRole.student);
+    });
+
+    test('enforces the expected permission matrix', () {
+      expect(
+        PermissionPolicy.allows(UserRole.admin, AppPermission.manageUsers),
+        isTrue,
+      );
+      expect(
+        PermissionPolicy.allows(
+          UserRole.lecturer,
+          AppPermission.manageSchedules,
+        ),
+        isTrue,
+      );
+      expect(
+        PermissionPolicy.allows(
+          UserRole.classLeader,
+          AppPermission.manageReminders,
+        ),
+        isTrue,
+      );
+      expect(
+        PermissionPolicy.allows(
+          UserRole.student,
+          AppPermission.manageReminders,
+        ),
+        isFalse,
+      );
+    });
+  });
+
+  group('Reminder', () {
+    test('maps the legacy tasks schema to the domain model', () {
+      final dueDate = DateTime.now().add(const Duration(days: 10));
+      final reminder = Reminder.fromMap({
+        'id': 7,
+        'judul': 'Ujian akhir',
+        'deskripsi': 'Ruang 301',
+        'created_by': 'user-id',
+        'kelas_id': 3,
+        'target_role': 'student',
+        'waktu_reminder': dueDate.toIso8601String(),
+        'priority': 'urgent',
+        'status': 'pending',
+      });
+
+      expect(reminder.title, 'Ujian akhir');
+      expect(reminder.targetClass, 3);
+      expect(reminder.targetRole, UserRole.student);
+      expect(reminder.priority, ReminderPriority.urgent);
+      expect(reminder.effectiveStatus, ReminderStatus.pending);
+    });
+
+    test('derives expired status for overdue pending reminders', () {
+      final reminder = Reminder(
+        id: 1,
+        title: 'Terlambat',
+        description: '',
+        createdBy: 'user-id',
+        targetClass: 1,
+        dueDate: DateTime.now().subtract(const Duration(minutes: 1)),
+        priority: ReminderPriority.high,
+        status: ReminderStatus.pending,
+      );
+
+      expect(reminder.effectiveStatus, ReminderStatus.expired);
+      expect(reminder.toMap()['priority'], 'high');
+      expect(reminder.toMap()['status'], 'pending');
+    });
+  });
+}
